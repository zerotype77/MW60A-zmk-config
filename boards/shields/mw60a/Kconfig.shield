#    default y

# config SSD1306
#     default y

# endif # ZMK_DISPLAY


# OLED디스플레이 노이즈 현상 제거
 if LVGL

 config LV_Z_VDB_SIZE
    default 64

 config LV_DPI_DEF
     default 148

 config LV_Z_BITS_PER_PIXEL
     default 1

 choice LV_COLOR_DEPTH
     default LV_COLOR_DEPTH_1
 endchoice

 endif # LVGL