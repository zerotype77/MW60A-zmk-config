# 이 kconfig.shield 파일은 MW60A 키보드 펌웨어의 일부임

if SHIELD_MW60A
config ZMK_KEYBOARD_NAME
    default "mw60a"

# ZMK Studio에 키맵 구조를 전달하기 위한 설정 활성화
# config ZMK_STUDIO
#     def_bool y


# 시프트 레지스터 사용을 위한 SPI 활성화, 줄 순서가 바뀌면 컴파일 에러.
# config SPI
#    default y

config ZMK_DISPLAY
    def_bool y

# ZMK 내부 디스플레이 라이브러리 및 드라이버 의존성 로드
config DISPLAY
    def_bool y

config SSD1306
    def_bool y

endif




