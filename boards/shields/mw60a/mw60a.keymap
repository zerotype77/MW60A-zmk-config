// 시작 키는 0번(Q에 해당)으로 할당됨
// 추후, 콤보는 최대한 줄이고, 특수문자를 <NUMBERS>레이어의 오른손으로 할당을 넘기자.

combos {
        compatible = "zmk,combos";
        combo_tab1{
            timeout-ms = <100>;
            key-positions = <23 33>;    // 'V' 키와 'shift' 키의 위치 번호
            bindings = <AS(TAB)>;      		// tab  발동 
            layers = <0>;               	// 0번(기본) 레이어에서만 작동
        };
        combo_esc {
            timeout-ms = <50>;
            key-positions = <24 33>;    // 'B' 키와 'shift' 키의 위치 번호
            bindings = <&kp ESC>;       // 발동될 키: esc
            layers = <0>;               // 0번(기본) 레이어에서만 작동
        };
        combo_sqt{
            timeout-ms = <100>;
            key-positions = <18 19>;    	// 'k' 키와 ';' 키의 위치 번호
            bindings = <AS(SQT)>;      	// 오토시프트+SINGLE_QUOTE 발동 (APOS/APOSTROPHE 가능)
            layers = <0>;               // 0번(기본) 레이어에서만 작동
        };

        combo_exc{
            timeout-ms = <100>;
            key-positions = <27 28>;    // '<' 키와 '>' 키의 위치 번호
            bindings = <&kp EXCLAMATION>;     //  느낌표(exclamation mark) 발동   QMK의 LSFT(KC_1)= &kp LS(A)
            layers = <0>;               // 0번(기본) 레이어에서만 작동
        };
		
        combo_insert{
            timeout-ms = <100>;
            key-positions = <28 29>;    	// '.' 키와 '/' 키의 위치 번호 
            bindings = <AS(INSERT)>;      		// INSERT  발동 
            layers = <0>;               	// 0번(기본) 레이어에서만 작동
        };

        combo_poweroff{
//        combo_powertoggle{
            timeout-ms = <100>;
            key-positions = <9 39>;    	// P 키와 = 키의 위치 번호
            bindings = <&ext_power EXT_POWER_OFF_CMD>;      		//   전원을 끈다
//            bindings = <&ext_power EP_TOG>;      		//   EP_TOG: 전원을 토글(켜져 있으면 끄고, 꺼져 있으면 켭니다).
//            layers = <0>;               	// 0번(기본) 레이어에서만 작동
        };
        combo_poweron{
            timeout-ms = <100>;
            key-positions = <9 38>;     	// P 키와 - 키의 위치 번호
            bindings = <&ext_power EXT_POWER_ON_CMD>;      		//   전원을 켠다.
//            layers = <0>;               	// 0번(기본) 레이어에서만 작동
        };
    };
/*  영타에서 빈번한 오타 발생에  따라 콤보를 줄이기 위함.

        combo_esc {
            timeout-ms = <50>;
            key-positions = <1 2>;    	// 'W' 키와 'E' 키의 물리적 위치 번호
            bindings = <&kp ESC>;       // 발동될 키: esc
            layers = <0>;               // 0번(기본) 레이어에서만 작동
        };
        
        combo_enter {
