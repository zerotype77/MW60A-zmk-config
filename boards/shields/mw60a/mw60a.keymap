// 시작 키는 0번(Q에 해당)으로 할당됨
// 추후, 콤보는 최대한 줄이고, 특수문자를 <NUMBERS>레이어의 오른손으로 할당을 넘기자.

combos {
        compatible = "zmk,combos";
        combo_esc {
            timeout-ms = <50>;
            key-positions = <1 2>;    	// 'W' 키와 'E' 키의 물리적 위치 번호
            bindings = <&kp ESC>;       // 발동될 키
            layers = <0>;               // 0번(기본) 레이어에서만 작동
        };
        
        combo_enter {
            timeout-ms = <100>;
            key-positions = <17 18>;    // 'K' 키와 'L' 키의 위치 번호
            bindings = <&kp ENTER>;     // Enter 발동
            layers = <0>;               // 0번(기본) 레이어에서만 작동
        };

        combo_tab1{
            timeout-ms = <100>;
            key-positions = <17 18>;    // 'L' 키와 ';' 키의 위치 번호
            bindings = <AS(TAB)>;      		// tab  발동 
            layers = <0>;               	// 0번(기본) 레이어에서만 작동
        };

        combo_backspace {
            timeout-ms = <100>;
            key-positions = <16 17>;    // 'L' 키와 'K' 키의 위치 번호
            bindings = <&kp BSPC>;      // BACK SPACE 발동
            layers = <0>;               // 0번(기본) 레이어에서만 작동
        };


        combo_sqt {
            timeout-ms = <100>;
            key-positions = <7 8>;    	// 'i' 키와 'o' 키의 위치 번호
            bindings = <AS(SQT)>;      	// 오토시프트+SINGLE_QUOTE 발동 (APOS/APOSTROPHE 가능)
            layers = <0>;               // 0번(기본) 레이어에서만 작동
        };

        combo_minus {
            timeout-ms = <100>;
            key-positions = <6 7>; 	   	// 'u' 키와 'i' 키의 위치 번호
            bindings = <AS(MINUS)>;     // MINUS 발동
            layers = <0>;               // 0번(기본) 레이어에서만 작동
        };

        combo_delete {
            timeout-ms = <100>;
            key-positions = <26 27>;    // 'm' 키와 '<' 키의 위치 번호
            bindings = <&kp DELETE>;    //  delete 발동
            layers = <0>;               // 0번(기본) 레이어에서만 작동
        };

        combo_exc{
            timeout-ms = <100>;
            key-positions = <27 28>;    // '<' 키와 '>' 키의 위치 번호
            bindings = <&kp LS(1)>;     //  느낌표(exclamation mark) 발동   QMK의 LSFT(KC_1)= &kp LS(A)
            layers = <0>;               // 0번(기본) 레이어에서만 작동
        };

        combo_grave{
            timeout-ms = <100>;
            key-positions = <0 1>;		// 'q' 키와 'w' 키의 위치 번호
            bindings = <AS(GRAVE)>;     // 오토시프트+` GRAVE 발동
            layers = <0>;               // 0번(기본) 레이어에서만 작동
        };

        combo_caps{
            timeout-ms = <100>;
            key-positions = <10 11>;   		// 'a' 키와 's' 키의 위치 번호
            bindings = <&kp CAPSLOCK>;      // 오토시프트+ tab  발동 
            layers = <0>;               	// 0번(기본) 레이어에서만 작동
        };

        combo_tab2{
            timeout-ms = <100>;
            key-positions = <21 22>;    	// 'x' 키와 'c' 키의 위치 번호 
            bindings = <AS(TAB)>;      		// tab  발동 
            layers = <0>;               	// 0번(기본) 레이어에서만 작동
        };

        combo_insert{
            timeout-ms = <100>;
            key-positions = <28 29>;    	// '.' 키와 '/' 키의 위치 번호 
            bindings = <AS(TAB)>;      		// INSERT  발동 
            layers = <0>;               	// 0번(기본) 레이어에서만 작동
        };


        combo_layer1lock{
            timeout-ms = <100>;
            key-positions = <35 37>;    	// '스페이스' 키와 '레이어3' 키의 위치 번호 
            bindings = <&mo 1>;      		// Layer 1 고정.
            layers = <0>;               	// 0번(기본) 레이어에서만 작동
        };

        combo_layer0lock{
            timeout-ms = <100>;
            key-positions = <35 37>;    	// '스페이스' 키와 '레이어3' 키의 위치 번호 
            bindings = <&mo 0>;      		// Layer 0 고정. 
            layers = <1>;               	// 1번(기본) 레이어에서만 작동. 누를 때 마다 토글되도록.
        };  

        combo_poweroff{
//        combo_powertoggle{
            timeout-ms = <100>;
            key-positions = <4 5>;    	// 'T' 키와 'Y' 키의 위치 번호 
            bindings = <&ext_power EXT_POWER_OFF_CMD>;      		//   전원을 끈다
//            bindings = <&ext_power EP_TOG>;      		//   EP_TOG: 전원을 토글(켜져 있으면 끄고, 꺼져 있으면 켭니다).
//            layers = <0>;               	// 0번(기본) 레이어에서만 작동
        };
        combo_poweron{
            timeout-ms = <100>;
            key-positions = <5 6>;    	// 'Y' 키와 'U' 키의 위치 번호 
            bindings = <&ext_power EXT_POWER_ON_CMD>;      		//   전원을 켠다.
//            layers = <0>;               	// 0번(기본) 레이어에서만 작동
        };
    };



// &as_ht LS(A) A

keymap {
    compatible = "zmk,keymap";
    
    // BASE 레이어    MO 0
    default_layer {
        display-name = "Base";
        bindings = <
// ╭───────────────────┬───────────────────┬───────────────────┬───────────────────┬───────────────────╮   ╭───────────────────┬───────────────────┬───────────────────┬───────────────────┬───────────────────╮
     &as_ht LS(Q) Q		&as_ht LS(W) W		&as_ht LS(E) E		&as_ht LS(R) R		&as_ht LS(T) T 			&as_ht LS(Y) Y		&as_ht LS(U) U		&as_ht LS(I) I		&as_ht LS(O) O		&as_ht LS(P) P
// ├───────────────────┬───────────────────┬───────────────────┬───────────────────┬───────────────────┤   ├───────────────────┬───────────────────┬───────────────────┬───────────────────┬───────────────────┤
     &as_ht LS(A) A		&as_ht LS(S) S		&as_ht LS(D) D		&as_ht LS(F) F		&as_ht LS(G) G			&as_ht LS(H) H		&as_ht LS(J) J		&as_ht LS(K) K		&as_ht LS(L) L		&as_ht LS(SEMICOLON) SEMICOLON
// ├───────────────────┬───────────────────┬───────────────────┬───────────────────┬───────────────────┤   ├───────────────────┬───────────────────┬───────────────────┬───────────────────┬───────────────────┤
     &as_ht LS(Z) Z		&as_ht LS(X) X		&as_ht LS(C) C		&as_ht LS(V) V		&as_ht LS(B) B			&as_ht LS(N) N		&as_ht LS(M) M		&as_ht LS(COMMA) COMMA	&as_ht LS(DOT) DOT	&as_ht LS(SLASH) SLASH
// ├───────────────────┬───────────────────┬───────────────────┬───────────────────┬─────────────────────┬─────────────────────┬───────────────────┬───────────────────┬───────────────────┬───────────────────┤
     &kp LEFT_ALT    &kp LEFT_GUI 		&kp LCTRL       &kp LSHFT       &lt 2 SPACE    	    	&mo 1		&lt 3 CAPS        &mo 4				&as_ht LS(MINUS) 		&as_ht LS(EQUAL)
// ╰───────────────────┴───────────────────┴───────────────────┴───────────────────┴─────────────────────┴─────────────────────┴───────────────────┴───────────────────┴───────────────────┴───────────────────╯
        >;
        /* 엔코더 정의 */  
//        sensor-bindings = <
// 테스트를 위해.             &encoder_msc_down_up SCRL_DOWN  SCRL_UP  &inc_dec_kp C_VOL_UP C_VOL_DN
//              &inc_dec_kp C_VOL_UP C_VOL_DN  &inc_dec_kp C_VOL_UP C_VOL_DN
//        >;
};

    // 1번 레이어   MO 1 
        adjust_layer {
            display-name = "Navigation";
            bindings = <
// ╭───────────────────┬───────────────────┬───────────────────┬───────────────────┬───────────────────╮   ╭───────────────────┬───────────────────┬───────────────────┬───────────────────┬───────────────────╮
        &kp LS(N9)		&kp LS(N0)			&macro000			&trans  			&trans					&kp LS(N3)			&kp HOME  			&kp UP     			&kp END    			&kp PG_UP
// ├───────────────────┬───────────────────┬───────────────────┬───────────────────┬───────────────────┤   ├───────────────────┬───────────────────┬───────────────────┬───────────────────┬───────────────────┤
        &trans        	&macro002  			&macro001			&macro003  			&trans         			&kp BSPC        	&kp LEFT    		&kp DOWN        	&kp RIGHT			&kp PG_DN      
// ├───────────────────┬───────────────────┬───────────────────┬───────────────────┬───────────────────┤   ├───────────────────┬───────────────────┬───────────────────┬───────────────────┬───────────────────┤
        &macro004		&macro005			&macro006			&macro007			&trans      	   		&macro009			&kp DEL			&as_ht LS(LEFT_BRACKET) &as_ht LS(RIGHT_BRACKET)	&kp INSERT
// ├───────────────────┬───────────────────┬───────────────────┬───────────────────┬─────────────────────┬─────────────────────┬───────────────────┬───────────────────┬───────────────────┬───────────────────┤
		&trans			&trans				&trans				&trans				&kp ENTER				&trans        		&trans      		&trans				&trans				&trans
// ╰───────────────────┴───────────────────┴───────────────────┴───────────────────┴─────────────────────┴─────────────────────┴───────────────────┴───────────────────┴───────────────────┴───────────────────╯
            >;
        /* 엔코더 정의 */
//            sensor-bindings = <
//                  &encoder_msc_down_up SCRL_LEFT  SCRL_RIGHT    &inc_dec_kp C_VOL_UP C_VOL_DN
//            >;
};


        // 2번 레이어   MO 2  
        number_layer {
            display-name = "Numbers";
            bindings = <
// ╭───────────────────┬───────────────────┬───────────────────┬───────────────────┬───────────────────╮   ╭───────────────────┬───────────────────┬───────────────────┬───────────────────┬───────────────────╮
	&as_ht LS(N1) N1	&as_ht LS(N2) N2	&as_ht LS(N3) N3	&as_ht LS(N4) N4	&as_ht LS(N5) N5		&as_ht LS(N6) N6	&as_ht LS(N7) N7	&as_ht LS(N8) N8	&as_ht LS(N9) N9	&as_ht LS(N0) N0
// ├───────────────────┬───────────────────┬───────────────────┬───────────────────┬───────────────────┤   ├───────────────────┬───────────────────┬───────────────────┬───────────────────┬───────────────────┤
	&kp C_VOL_UP		&kp C_MUTE			&trans          	&trans				&trans					&trans				&trans				&trans				&trans				&trans
// ├───────────────────┬───────────────────┬───────────────────┬───────────────────┬───────────────────┤   ├───────────────────┬───────────────────┬───────────────────┬───────────────────┬───────────────────┤
	&kp C_VOL_DN		&kp C_PLAY_PAUSE	&trans				&trans				&trans					&trans				&trans				&trans				&trans				&trans
// ├───────────────────┬───────────────────┬───────────────────┬───────────────────┬─────────────────────┬─────────────────────┬───────────────────┬───────────────────┬───────────────────┬───────────────────┤
	&trans         		&trans          	&trans				&trans      		&trans	        		&trans      		&trans  			&trans			 	&trans				&trans
// ╰───────────────────┴───────────────────┴───────────────────┴───────────────────┴─────────────────────┴─────────────────────┴───────────────────┴───────────────────┴───────────────────┴───────────────────╯
            >;
 };


        // 3번 레이어      MO 3
