// 시작 키는 0번(Q에 해당)으로 할당됨
combos {
        compatible = "zmk,combos";
        combo_esc {
            timeout-ms = <50>;
            key-positions = <1 2>;    	// 'W' 키와 'E' 키의 물리적 위치 번호
            bindings = <&kp ESC>;       // 발동될 키
            layers = <0>;               // 0번(기본) 레이어에서만 작동
        };
        
        combo_enter {
            timeout-ms = <100>;
            key-positions = <17 18>;    // 'K' 키와 'L' 키의 위치 번호
            bindings = <&kp ENTER>;     // Enter 발동
            layers = <0>;               // 0번(기본) 레이어에서만 작동
        };

        combo_backspace {
            timeout-ms = <100>;
            key-positions = <16 17>;    // 'L' 키와 'K' 키의 위치 번호
            bindings = <&kp BSPC>;      // BACK SPACE 발동
            layers = <0>;               // 0번(기본) 레이어에서만 작동
        };


        combo_sqt {
            timeout-ms = <100>;
            key-positions = <7 8>;    	// 'i' 키와 'o' 키의 위치 번호
            bindings = <&as SQT>;      	// 오토시프트+SINGLE_QUOTE 발동 (APOS/APOSTROPHE 가능)
            layers = <0>;               // 0번(기본) 레이어에서만 작동
        };

        combo_minus {
            timeout-ms = <100>;
            key-positions = <6 7>; 	   	// 'u' 키와 'i' 키의 위치 번호
            bindings = <&as MINUS>;     // MINUS 발동
            layers = <0>;               // 0번(기본) 레이어에서만 작동
        };

        combo_delete {
            timeout-ms = <100>;
            key-positions = <25 26>;    // 'm' 키와 'm' 키의 위치 번호
            bindings = <&kp DELETE>;    //  delete 발동
            layers = <0>;               // 0번(기본) 레이어에서만 작동
        };

        combo_exc{
            timeout-ms = <100>;
            key-positions = <27 28>;    // '<' 키와 '>' 키의 위치 번호
            bindings = <&kp LS(1)>;     //  느낌표(exclamation mark) 발동   QMK의 LSFT(KC_1)= &kp LS(A)
            layers = <0>;               // 0번(기본) 레이어에서만 작동
        };

        combo_grave{
            timeout-ms = <100>;
            key-positions = <0 1>;		// 'q' 키와 'w' 키의 위치 번호
            bindings = <&as GRAVE>;     // 오토시프트+` GRAVE 발동
            layers = <0>;               // 0번(기본) 레이어에서만 작동
        };

        combo_caps{
            timeout-ms = <100>;
            key-positions = <10 11>;   		// 'a' 키와 's' 키의 위치 번호
            bindings = <&kp CAPSLOCK>;      // 오토시프트+ tab  발동 
            layers = <0>;               	// 0번(기본) 레이어에서만 작동
        };

        combo_tab{
            timeout-ms = <100>;
            key-positions = <21 22>;    	// 'x' 키와 'c' 키의 위치 번호 
            bindings = <&as TAB>;      		// tab  발동 
            layers = <0>;               	// 0번(기본) 레이어에서만 작동
        };

        combo_layer1lock{
            timeout-ms = <100>;
            key-positions = <35 37>;    	// '스페이스' 키와 '레이어3' 키의 위치 번호 
            bindings = <&mo 2>;      		// Layer 1 고정.
            layers = <0>;               	// 0번(기본) 레이어에서만 작동
        };

        combo_layer0lock{
            timeout-ms = <100>;
            key-positions = <35 37>;    	// '스페이스' 키와 '레이어3' 키의 위치 번호 
            bindings = <&mo 1>;      		// Layer 0 고정. 
            layers = <1>;               	// 1번(기본) 레이어에서만 작동. 누를 때 마다 토글되도록.
        };

        combo_poweroff{
//        combo_powertoggle{
            timeout-ms = <100>;
            key-positions = <4 5>;    	// 'T' 키와 'Y' 키의 위치 번호 
            bindings = <&ext_power EXT_POWER_OFF_CMD>;      		//   전원을 끈다
//            bindings = <&ext_power EP_TOG>;      		//   EP_TOG: 전원을 토글(켜져 있으면 끄고, 꺼져 있으면 켭니다).
//            layers = <0>;               	// 0번(기본) 레이어에서만 작동
        };
        combo_poweron{
            timeout-ms = <100>;
            key-positions = <5 6>;    	// 'Y' 키와 'U' 키의 위치 번호 
            bindings = <&ext_power EXT_POWER_ON_CMD>;      		//   전원을 켠다.
//            layers = <0>;               	// 0번(기본) 레이어에서만 작동
        };
    };





keymap {
    compatible = "zmk,keymap";
    
    // 0번 레이어    MO 1
    default_layer {
        display-name = "Base";
        bindings = <
// ╭───────────────┬────────────────┬───────────────┬───────────────┬─────────────╮      ╭───────────────┬───────────────┬───────────────┬─────────────────┬──────────────────╮
     &as Q           &as W            	&as E           &as R            &as T   	          	&as Y       &as U           &as I           &as O 			&as SEMICOLON
// ├───────────────┼────────────────┼───────────────┼───────────────┼─────────────┤      ├───────────────┼───────────────┼───────────────┼─────────────────┼──────────────────┤
     &as A           &as S            	&as D           &as F            &as G       	    	&as H       &as J           &as K           &as L			&as P
// ├───────────────┼────────────────┼───────────────┼───────────────┼─────────────┤      ├───────────────┼───────────────┼───────────────┼─────────────────┼──────────────────┤
     &as Z           &as X            	&as C           &as V            &as B        			&as N		&as M			&as COMMA  		&as DOT			&as SLASH
// ├───────────────┼────────────────┼───────────────┼───────────────┼────────────────┬───────────────────┼───────────────┼───────────────┼─────────────────┼──────────────────┤
     &kp LEFT_ALT    &kp LEFT_GUI 		&kp LCTRL       &kp LSHFT       &lt 3 SPACE    	    	&mo 2		&kp CAPS        &mo 4			&as MINUS 		&as EQUAL
// ╰───────────────┴────────────────┴───────────────┴───────────────┴────────────────┴───────────────────┴───────────────┴───────────────┴─────────────────┴──────────────────╯
        >;
        /* 엔코더 정의 */  
//        sensor-bindings = <
// 테스트를 위해.             &encoder_msc_down_up SCRL_DOWN  SCRL_UP  &inc_dec_kp C_VOL_UP C_VOL_DN
//              &inc_dec_kp C_VOL_UP C_VOL_DN  &inc_dec_kp C_VOL_UP C_VOL_DN
//        >;
};


    // 1번 레이어   MO 2     
        adjust_layer {
            display-name = "Navigation";
            bindings = <
// ╭───────────────┬────────────────┬───────────────┬───────────────┬─────────────╮      ╭───────────────┬───────────────┬───────────────┬─────────────────┬──────────────────╮
        &kp LS(9)		&kp LS(10)		&macro000		&trans  		&trans				&kp LS(3)		&kp HOME  		&kp UP     		&kp END    		&kp PG_UP
// ├───────────────┼────────────────┼───────────────┼───────────────┼─────────────┤      ├───────────────┼───────────────┼───────────────┼─────────────────┼──────────────────┤
        &kp 2        	&macro002  		&macro001		&macro003  		&trans         		&kp BSPC        &kp LEFT    	&kp DOWN        &kp RIGHT		&kp PG_DN      
// ├───────────────┼────────────────┼───────────────┼───────────────┼─────────────┤      ├───────────────┼───────────────┼───────────────┼─────────────────┼──────────────────┤
        &macro004		&macro005		&macro006		&macro007		&trans      	   	&macro009		&kp DEL     	&kp INSERT 	    &as LEFT_BRACKET &as RIGHT_BRACKET
// ├───────────────┼────────────────┼───────────────┼───────────────┼────────────────┬───────────────────┼───────────────┼───────────────┼─────────────────┼──────────────────┤
        &trans			&trans			&trans			&trans			&kp ENTER			&trans        	&trans      	&trans			&trans			&trans
// ╰───────────────┴────────────────┴───────────────┴───────────────┴────────────────┴───────────────────┴───────────────┴───────────────┴─────────────────┴──────────────────╯
            >;
        /* 엔코더 정의 */
//            sensor-bindings = <
//                  &encoder_msc_down_up SCRL_LEFT  SCRL_RIGHT    &inc_dec_kp C_VOL_UP C_VOL_DN
//            >;
};


        // 2번 레이어   MO 3     
        number_layer {
            display-name = "Numbers";
            bindings = <
// ╭───────────────┬────────────────┬───────────────┬───────────────┬─────────────╮      ╭───────────────┬───────────────┬───────────────┬─────────────────┬──────────────────╮
        &kp N1           &kp N2         &kp N3          &kp N4           &kp N5				&kp N6          &kp N7          &kp N8          &kp N9          &kp N0
// ├───────────────┼────────────────┼───────────────┼───────────────┼─────────────┤      ├───────────────┼───────────────┼───────────────┼─────────────────┼──────────────────┤
        &kp 3           &trans         &trans          &trans           &trans         	&kp BSPC        &kp LEFT    	&kp DOWN        &kp RIGHT		&kp PG_DN      
// ├───────────────┼────────────────┼───────────────┼───────────────┼─────────────┤      ├───────────────┼───────────────┼───────────────┼─────────────────┼──────────────────┤
        &trans           &trans         &trans          &trans           &trans         	&trans       	&kp DEL     	&trans   		&as LEFT_BRACKET &as RIGHT_BRACKET
// ├───────────────┼────────────────┼───────────────┼───────────────┼────────────────┬───────────────────┼───────────────┼───────────────┼─────────────────┼──────────────────┤
        &trans           &trans         &trans          &trans           &trans      	&trans        	&trans      	&trans  		&trans			&trans
// ╰───────────────┴────────────────┴───────────────┴───────────────┴────────────────┴───────────────────┴───────────────┴───────────────┴─────────────────┴──────────────────╯       
            >;

};
        // 3번 레이어      MO 4          
        function_layer {
            display-name = "Function";
            bindings = <
// ╭───────────────┬────────────────┬───────────────┬───────────────┬─────────────╮      ╭───────────────┬───────────────┬───────────────┬─────────────────┬──────────────────╮
        &kp F1           &kp F2         &kp F3          &kp F4           &kp F5				&kp F6          &kp F7          &kp F8          &kp F9          &kp F10
// ├───────────────┼────────────────┼───────────────┼───────────────┼─────────────┤      ├───────────────┼───────────────┼───────────────┼─────────────────┼──────────────────┤
        &kp 4           &trans         &trans          &trans           &trans         		&trans           &trans         &trans          &trans           &trans
// ├───────────────┼────────────────┼───────────────┼───────────────┼─────────────┤      ├───────────────┼───────────────┼───────────────┼─────────────────┼──────────────────┤
        &bt BT_SEL 0	&bt BT_SEL 1	&bt BT_SEL 2	&bt BT_SEL 3	&bt BT_SEL 4       	&bt BT_CLR   	&out OUT_BLE	&out OUT_USB	&trans           &trans
// ├───────────────┼────────────────┼───────────────┼───────────────┼────────────────┬───────────────────┼───────────────┼───────────────┼─────────────────┼──────────────────┤
        &trans           &trans         &trans          &trans           &trans     		&trans        	&trans      	&trans  		&kp F11			&kp F12
// ╰───────────────┴────────────────┴───────────────┴───────────────┴────────────────┴───────────────────┴───────────────┴───────────────┴─────────────────┴──────────────────╯             
            >;


};

        // 4번 레이어 / 예비1     MO 5  
        extra1 {
            status = "reserved";
        };

        // 5번 레이어 / 예비2     MO 6
        extra2 {
            status = "reserved";    
        };

        // 6번 레이어 / 예비2     MO 7
        extra3 {
            status = "reserved";    
        };

        // 7번 레이어 / 예비2     MO 8
        extra4 {
            status = "reserved";    
        };

        // 8번 레이어 / 예비2     MO 9
        extra5 {
            status = "reserved";    
        };

        // 9번 레이어 / 예비2     MO 10
        extra6 {
            status = "reserved";    
        };

        // 10번 레이어 / 예비2     MO 11
        extra6 {
            status = "reserved";    
        };

        // 11번 레이어 / 예비2     MO 12
        extra6 {
            status = "reserved";    
        };

	};
};

