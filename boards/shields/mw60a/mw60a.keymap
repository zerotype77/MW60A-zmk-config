        combo_minus {
            timeout-ms = <100>;
            key-positions = <6 7>; 	   	// 'u' 키와 'i' 키의 위치 번호
            bindings = <AS(MINUS)>;     // MINUS 발동
            layers = <0>;               // 0번(기본) 레이어에서만 작동
