// Autoshift Macro
// #define AS(keycode) &as LS(keycode) keycode     
// 위 오토시프트 매크로는 대문자가 된 후에도 연속으로 눌린 상태여서 사용하기 불편함.


// app/include/dt-bindings/zmk/outputs.h
// &out OUT_USB 키보드 출력을 USB로 보내는 동작
// &out OUT_BLE 키보드 출력을 현재 블루투스 프로필로 보내는 동작


// app/include/dt-bindings/zmk/bt.h
// &bt BT_CLR   선택한 프로필에 대해 쌍 호스트를 제거하기 위한 비헤이비어 결합
// &bt BT_NXT   // &bt BT_PRV   다음 / 이전 프로필을 선택하는 행동 바인딩
// &bt BT_SEL 1   두 번째 프로파일을 선택하는 동작 결속(전달된 매개변수는 0 기반)




// ZMK 공식 홈에서 제시한 오토시프트
#define AS(keycode) &as LS(keycode) keycode     // Autoshift Macro

/{
    behaviors {





// Layer-Tap 을 위한 lt 정의 
        lt: layer_tap {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <170>;
            bindings = <&mo>, <&kp>;
            display-name = "Layer-Tap";
        };


// 스플릿키보드갤러리에서 질문에 답변으로 받은 오토시프트 정의방법
// 사용은 : &as_ht LS(A) A

	as_ht: hold_tap {
		compatible = "zmk,behavior-hold-tap";
		label = "AUTOSHIFT_HOLD_TAP";
		#binding-cells = <2>;
		tapping-term-ms = <175>;
		bindings = <&kp>, <&kp>;
		};


