        };

        combo_grave{
            timeout-ms = <100>;
            key-positions = <0 1>;		// 'q' 키와 'w' 키의 위치 번호
            bindings = <AS(GRAVE)>;     // 오토시프트+` GRAVE 발동
            layers = <0>;               // 0번(기본) 레이어에서만 작동
        };

        combo_caps{
            timeout-ms = <100>;
            key-positions = <10 11>;   		// 'a' 키와 's' 키의 위치 번호
            bindings = <&kp CAPSLOCK>;      // CapsLock  발동 
            layers = <0>;               	// 0번(기본) 레이어에서만 작동
        };

        combo_tab2{
            timeout-ms = <100>;
            key-positions = <21 22>;    	// 'x' 키와 'c' 키의 위치 번호 
            bindings = <AS(TAB)>;      		// tab  발동 
            layers = <0>;               	// 0번(기본) 레이어에서만 작동
        };

		*/


// &as_ht LS(A) A

keymap {
    compatible = "zmk,keymap";
    
    // BASE 레이어    MO 0
    default_layer {
        display-name = "Base";
        bindings = <

// ╭───────────────────┬───────────────────┬───────────────────┬───────────────────┬───────────────────╮   ╭───────────────────┬───────────────────┬───────────────────┬───────────────────┬───────────────────╮
     AS(Q)				AS(W) 				AS(E) 				AS(R) 				AS(T) 		 			AS(Y) 				AS(U) 				AS(I) 				AS(O) 				AS(P) 
// ├───────────────────┬───────────────────┬───────────────────┬───────────────────┬───────────────────┤   ├───────────────────┬───────────────────┬───────────────────┬───────────────────┬───────────────────┤
     AS(A) 				AS(S) 				AS(D) 				AS(F) 				AS(G) 					AS(H) 				AS(J) 				AS(K) 				AS(L) 				AS(SEMICOLON)
// ├───────────────────┬───────────────────┬───────────────────┬───────────────────┬───────────────────┤   ├───────────────────┬───────────────────┬───────────────────┬───────────────────┬───────────────────┤
     AS(Z) 				AS(X) 				AS(C) 				AS(V) 				AS(B) 					AS(N) 				AS(M) 				AS(COMMA) 			AS(DOT) 			AS(SLASH)
// ├───────────────────┬───────────────────┬───────────────────┬───────────────────┬─────────────────────┬─────────────────────┬───────────────────┬───────────────────┬───────────────────┬───────────────────┤
     &kp LEFT_ALT    	&kp LEFT_GUI 		&kp LCTRL       	&kp LSHFT       	&lt 2 SPACE    	    	&mo 1				&lt 3 RIGHT_ALT   	&mo 4				AS(MINUS) 			AS(EQUAL) 
// ╰───────────────────┴───────────────────┴───────────────────┴───────────────────┴─────────────────────┴─────────────────────┴───────────────────┴───────────────────┴───────────────────┴───────────────────╯
        >;
        /* 엔코더 정의 */  
//        sensor-bindings = <
// 테스트를 위해.             &encoder_msc_down_up SCRL_DOWN  SCRL_UP  &inc_dec_kp C_VOL_UP C_VOL_DN
//              &inc_dec_kp C_VOL_UP C_VOL_DN  &inc_dec_kp C_VOL_UP C_VOL_DN
//        >;
};

    // 1번 레이어   MO 1 
        adjust_layer {
            display-name = "Navigation";
            bindings = <

// ╭───────────────────┬───────────────────┬───────────────────┬───────────────────┬───────────────────╮   ╭───────────────────┬───────────────────┬───────────────────┬───────────────────┬───────────────────╮
        &kp ESC			AS(GRAVE)			&macro000			&trans  			&trans					&kp LS(N3)			&kp HOME  			&kp UP     			&kp END    			&kp PG_UP
// ├───────────────────┬───────────────────┬───────────────────┬───────────────────┬───────────────────┤   ├───────────────────┬───────────────────┬───────────────────┬───────────────────┬───────────────────┤
        AS(TAB)        	&macro002  			&macro001			&macro003  			&trans         			&kp CAPS			&kp LEFT    		&kp DOWN        	&kp RIGHT			&kp PG_DN
// ├───────────────────┬───────────────────┬───────────────────┬───────────────────┬───────────────────┤   ├───────────────────┬───────────────────┬───────────────────┬───────────────────┬───────────────────┤
        &macro004		&macro005			&macro006			&macro007			&trans      	   		&trans				&kp ENTER			&kp BSPC			&kp DEL				&kp INSERT
// ├───────────────────┬───────────────────┬───────────────────┬───────────────────┬─────────────────────┬─────────────────────┬───────────────────┬───────────────────┬───────────────────┬───────────────────┤
		&trans			&trans				&trans				&trans				&trans					&trans        		&trans      		&trans				&kp RCTRL			&kp K_APP
// ╰───────────────────┴───────────────────┴───────────────────┴───────────────────┴─────────────────────┴─────────────────────┴───────────────────┴───────────────────┴───────────────────┴───────────────────╯
            >;
        /* 엔코더 정의 */
//            sensor-bindings = <
//                  &encoder_msc_down_up SCRL_LEFT  SCRL_RIGHT    &inc_dec_kp C_VOL_UP C_VOL_DN
//            >;
};

        // 2번 레이어   MO 2  
        number_layer {
            display-name = "Numbers";
            bindings = <
// ╭───────────────────┬───────────────────┬───────────────────┬───────────────────┬───────────────────╮   ╭───────────────────┬───────────────────┬───────────────────┬───────────────────┬───────────────────╮
	AS(N1) 				AS(N2) 				AS(N3) 				AS(N4) 				AS(N5) 					AS(N6) 				AS(N7) 				AS(N8) 				AS(N9) 				AS(N0)
	//	&as_ht LS(N1) N1	&as_ht LS(N2) N2	&as_ht LS(N3) N3	&as_ht LS(N4) N4	&as_ht LS(N5) N5		&as_ht LS(N6) N6	&as_ht LS(N7) N7	&as_ht LS(N8) N8	&as_ht LS(N9) N9	&as_ht LS(N0) N0	
// ├───────────────────┬───────────────────┬───────────────────┬───────────────────┬───────────────────┤   ├───────────────────┬───────────────────┬───────────────────┬───────────────────┬───────────────────┤
	&trans				&trans				&trans          	&kp C_MUTE			&kp C_VOL_UP			&trans				&trans				&trans				&trans				AS(SQT)
// ├───────────────────┬───────────────────┬───────────────────┬───────────────────┬───────────────────┤   ├───────────────────┬───────────────────┬───────────────────┬───────────────────┬───────────────────┤
	&trans				&trans				&trans				&kp C_PLAY_PAUSE	&kp C_VOL_DN			&trans				&trans				AS(LEFT_BRACKET) 	AS(RIGHT_BRACKET)	AS(BACKSLASH)
// ├───────────────────┬───────────────────┬───────────────────┬───────────────────┬─────────────────────┬─────────────────────┬───────────────────┬───────────────────┬───────────────────┬───────────────────┤
	&trans         		&trans          	&trans				&trans      		&trans	        		&trans      		&kp CAPS	 		&trans			 	&trans				&trans
// ╰───────────────────┴───────────────────┴───────────────────┴───────────────────┴─────────────────────┴─────────────────────┴───────────────────┴───────────────────┴───────────────────┴───────────────────╯
            >;
 };

        // 3번 레이어      MO 3
        function_layer {
            display-name = "Function";
            bindings = <
// ╭───────────────────┬───────────────────┬───────────────────┬───────────────────┬───────────────────╮   ╭───────────────────┬───────────────────┬───────────────────┬───────────────────┬───────────────────╮
	&kp F1 	    		&kp F2         		&kp F3     			&kp F4				&kp F5					&kp F6			    &kp F7	         	&kp F8          	&kp F9          	&kp F10
// ├───────────────────┬───────────────────┬───────────────────┬───────────────────┬───────────────────┤   ├───────────────────┬───────────────────┬───────────────────┬───────────────────┬───────────────────┤
	&trans				&trans				&trans				&trans         		&trans     				&trans				&trans          	&trans     			&trans				&trans	
// ├───────────────────┬───────────────────┬───────────────────┬───────────────────┬───────────────────┤   ├───────────────────┬───────────────────┬───────────────────┬───────────────────┬───────────────────┤
	&bt BT_SEL 0		&bt BT_SEL 1		&bt BT_SEL 2		&bt BT_SEL 3		&bt BT_SEL 4       		&out OUT_BLE		&out OUT_USB		&trans				&trans				&bt BT_CLR
// ├───────────────────┬───────────────────┬───────────────────┬───────────────────┬─────────────────────┬─────────────────────┬───────────────────┬───────────────────┬───────────────────┬───────────────────┤
	&trans           	&trans         		&trans          	&trans           	&trans     				&trans        		&trans      		&trans  			&kp F11				&kp F12
// ╰───────────────────┴───────────────────┴───────────────────┴───────────────────┴─────────────────────┴─────────────────────┴───────────────────┴───────────────────┴───────────────────┴───────────────────╯
            >;
};

        // 4번 레이어   MO 4
        pointer_layer {
            display-name = "Pointer";
            bindings = <
